  "rules": {
    "grain.wheat.flour": {
      "allergies": {
        "wheat_gluten": {
          "action": "substitute_category",
          "to_category": "grain.gluten_free.flour",
          "amount_policy": "keep_same",
          "reason": "Contains wheat/gluten"
        }
      }
    },

    "sodium.salt": {
      "labs": {
        "CREATININE_HIGH": {
          "action": "reduce_amount",
          "reduce_ratio": 0.50,
          "reason": "Kidney-friendly sodium reduction"
        }
      },
      "diets": {
        "low_sodium": {
          "action": "reduce_amount",
          "reduce_ratio": 0.50,
          "reason": "Low sodium preference"
        }

      }
    },

    "fat.vegetable_oil": {
      "diets": {
        "low_fat": {
          "action": "reduce_amount",
          "reduce_ratio": 0.25,
          "reason": "Low-fat preference: reduce added oil"
        }
      }
    },

    "dairy.butter_ghee": {
      "allergies": {
        "dairy": {
          "action": "substitute_category",
          "to_category": "fat.olive_oil",
          "amount_policy": "butter_to_olive_oil_0p75",
          "reason": "Dairy allergy"
        }
      },
      "diets": {
        "low_fat": {
          "action": "substitute_category",
          "to_category": "fat.olive_oil",
          "amount_policy": "butter_to_olive_oil_0p75",
          "reason": "Low-fat preference: replace saturated fat source"
        }
      },
      "labs": {
        "LDL_HIGH": {
          "action": "substitute_category",
          "to_category": "fat.olive_oil",
          "amount_policy": "butter_to_olive_oil_0p75",
          "reason": "Reduce saturated fat for LDL"
        },
        "TRIGLYCERIDES_HIGH": {
          "action": "substitute_category",
          "to_category": "fat.olive_oil",
          "amount_policy": "butter_to_olive_oil_0p75",
          "reason": "Reduce saturated fat for triglycerides"
        }
      }
    },

    "protein.animal.poultry": {
      "diets": {
        "high_protein": {
          "action": "increase_amount",
          "increase_ratio": 0.20,
          "reason": "High-protein preference"
        }
      },
      "labs": {
        "CREATININE_HIGH": {
          "action": "block_high_protein_increase",
          "reason": "Creatinine high: avoid increasing protein load"
        }
      }
    }
  },

  "defaults": {
    "no_rule_behavior": "keep_and_report",
    "report_prefix": "[Step3]"
  }
